registerTemplate("o-spreadsheet-LinkDisplay", `/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.xml`, `<t t-name="o-spreadsheet-LinkDisplay" xml:space="preserve">
    <div class="o-link-tool d-flex align-items-center">

