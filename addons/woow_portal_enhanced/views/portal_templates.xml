<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Inherit portal.portal_my_home to prepend search bar,         -->
    <!-- notification preview, and admin banner.                      -->
    <!-- ============================================================ -->
    <template id="portal_my_home_enhanced" name="Woow Enhanced Portal Home"
              inherit_id="portal.portal_my_home" priority="10">

        <!-- Admin Banner — before everything -->
        <xpath expr="//div[hasclass('o_portal_my_home')]" position="before">
            <t t-if="is_internal_user">
                <div class="wpe-admin-banner alert alert-info d-flex align-items-center justify-content-between mb-0 rounded-0 d-print-none"
                     role="alert">
                    <span>
                        <i class="fa fa-info-circle me-1"/>
                        您正在以管理員身份瀏覽 Portal
                    </span>
                    <a href="/odoo" class="btn btn-sm btn-outline-primary">
                        <i class="fa fa-arrow-left me-1"/>返回後台
                    </a>
                </div>
            </t>
        </xpath>

        <!-- Search bar + Notification preview — before the module grid -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">

            <!-- ① Search Bar -->
            <div class="wpe-search-bar mb-3">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fa fa-search text-muted"/>
                    </span>
                    <input type="text"
                           id="wpe_module_search"
                           class="form-control border-start-0"
                           placeholder="搜尋模組..."/>
                </div>
            </div>

            <!-- ② Notification Preview Card -->
            <div class="wpe-notification-preview card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0 fw-bold">
                            近期通知
                            <t t-if="unread_notif_count">
                                <span class="badge bg-danger ms-2"
                                      style="font-size: 0.7rem; vertical-align: middle;"
                                      data-unread-badge="1">
                                    <t t-esc="unread_notif_count"/>
                                </span>
                            </t>
                        </h5>
                        <a href="/my/notifications" class="wpe-view-all-link">
                            查看全部 <i class="fa fa-angle-right ms-1"/>
                        </a>
                    </div>

                    <t t-if="notification_previews">
                        <t t-foreach="notification_previews" t-as="notif">
                            <a t-att-href="notif['document_url'] if notif['document_url'] != '#' else '/my/notifications'"
                               class="wpe-notification-item d-flex align-items-start text-decoration-none">
                                <div class="wpe-notification-icon me-3">
                                    <i t-attf-class="fa #{notif['icon']} fa-lg"/>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold text-dark">
                                        <t t-esc="notif['subject']"/>
                                    </div>
                                    <small class="text-muted">
                                        <t t-esc="notif['record_name']"/>
                                        <t t-if="notif.get('author_name')">
                                            <span class="ms-2">
                                                <i class="fa fa-user-o me-1"/>
                                                <t t-esc="notif['author_name']"/>
                                            </span>
                                        </t>
                                    </small>
                                </div>
                                <i class="fa fa-angle-right text-muted align-self-center"/>
                            </a>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="text-center text-muted py-3">
                            <i class="fa fa-check-circle fa-2x mb-2 d-block"/>
                            沒有新的通知
                        </div>
                    </t>
                </div>
            </div>

        </xpath>

        <!-- Wrap the module grid in our container for search filtering -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="attributes">
            <attribute name="id">wpe_module_grid</attribute>
        </xpath>

    </template>

    <!-- ============================================================ -->
    <!-- Notification List Page — /my/notifications                   -->
    <!-- 3 tabs: Mail Message / Mail Notification / Mail Activity     -->
    <!-- Portal users: Message + Notification only                    -->
    <!-- Backend users: all 3 tabs                                    -->
    <!-- ============================================================ -->
    <template id="portal_notifications_page" name="Portal Notifications Page">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <div class="container py-3">

                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0 fw-bold">通知中心</h4>
                    <a href="/my/home" class="btn btn-sm btn-outline-secondary">
                        <i class="fa fa-arrow-left me-1"/>返回
                    </a>
                </div>

                <!-- Tabs -->
                <div class="wpe-notif-tabs mb-3">
                    <a t-attf-href="/my/notifications?tab=all"
                       t-attf-class="wpe-notif-tab #{'active' if current_tab == 'all' else ''}">
                        全部
                        <t t-if="notification_total">
                            <span class="badge bg-secondary ms-1">
                                <t t-esc="notification_total"/>
                            </span>
                        </t>
                    </a>
                    <a t-attf-href="/my/notifications?tab=message"
                       t-attf-class="wpe-notif-tab #{'active' if current_tab == 'message' else ''}">
                        留言
                        <t t-if="message_count">
                            <span class="badge bg-secondary ms-1">
                                <t t-esc="message_count"/>
                            </span>
                        </t>
                    </a>
                    <a t-attf-href="/my/notifications?tab=notification"
                       t-attf-class="wpe-notif-tab #{'active' if current_tab == 'notification' else ''}">
                        通知
                        <t t-if="sys_notif_count">
                            <span class="badge bg-secondary ms-1">
                                <t t-esc="sys_notif_count"/>
                            </span>
                        </t>
                    </a>
                    <!-- Activity tab: internal users only -->
                    <t t-if="is_internal_user">
                        <a t-attf-href="/my/notifications?tab=activity"
                           t-attf-class="wpe-notif-tab #{'active' if current_tab == 'activity' else ''}">
                            待辦
                            <t t-if="activity_count">
                                <span class="badge bg-secondary ms-1">
                                    <t t-esc="activity_count"/>
                                </span>
                            </t>
                        </a>
                    </t>
                </div>

                <!-- Notification List -->
                <div class="wpe-notif-list" id="wpe_notif_list">
                    <t t-if="notification_items">
                        <t t-foreach="notification_items" t-as="item">
                            <!-- Notification-type item (mail.notification) -->
                            <t t-if="item.get('notif_id')">
                                <div t-attf-class="wpe-notif-card-wrapper #{'wpe-notif-read' if item['is_read'] else 'wpe-notif-unread'}"
                                     t-att-data-notif-id="item['notif_id']"
                                     data-item-type="notification">
                                    <div class="wpe-notif-swipe-bg">
                                        <i class="fa fa-check"/>
                                        <span>已讀</span>
                                    </div>
                                    <div class="wpe-notif-card" data-action="show-detail">
                                        <div class="wpe-notif-card-icon">
                                            <i t-attf-class="fa #{item['icon']}"/>
                                        </div>
                                        <div class="wpe-notif-card-body">
                                            <div class="wpe-notif-card-title">
                                                <t t-esc="item['subject']"/>
                                            </div>
                                            <div class="wpe-notif-card-meta">
                                                <span class="wpe-notif-card-source">
                                                    <t t-esc="item['record_name']"/>
                                                </span>
                                                <span class="wpe-notif-card-date">
                                                    <t t-esc="item['time_ago']"/>
                                                </span>
                                            </div>
                                            <t t-if="item.get('tracking_summary')">
                                                <div class="wpe-notif-card-tracking">
                                                    <small class="text-muted">
                                                        <i class="fa fa-exchange me-1"/>
                                                        <t t-esc="item['tracking_summary']"/>
                                                    </small>
                                                </div>
                                            </t>
                                            <t t-if="item.get('body_preview') and not item.get('tracking_summary')">
                                                <div class="wpe-notif-card-preview">
                                                    <small class="text-muted">
                                                        <t t-esc="item['body_preview']"/>
                                                    </small>
                                                </div>
                                            </t>
                                        </div>
                                        <div class="wpe-notif-card-hint">
                                            <t t-if="not item['is_read']">
                                                <span class="wpe-unread-dot"/>
                                            </t>
                                            <i class="fa fa-angle-right text-muted"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                            <!-- Activity-type item (mail.activity) -->
                            <t t-if="item.get('activity_id')">
                                <div class="wpe-notif-card-wrapper wpe-notif-unread"
                                     t-att-data-activity-id="item['activity_id']"
                                     data-item-type="activity">
                                    <div class="wpe-notif-swipe-bg">
                                        <i class="fa fa-check"/>
                                        <span>已完成</span>
                                    </div>
                                    <div class="wpe-notif-card" data-action="show-detail">
                                        <div class="wpe-notif-card-icon">
                                            <i t-attf-class="fa #{item['icon']}"/>
                                        </div>
                                        <div class="wpe-notif-card-body">
                                            <div class="wpe-notif-card-title">
                                                <t t-esc="item['summary']"/>
                                            </div>
                                            <div class="wpe-notif-card-meta">
                                                <span class="wpe-notif-card-source">
                                                    <t t-esc="item['res_name']"/>
                                                </span>
                                                <t t-if="item.get('date_deadline')">
                                                    <span class="wpe-notif-card-date">
                                                        <i class="fa fa-calendar-o me-1"/>
                                                        <t t-esc="item['date_deadline']"/>
                                                    </span>
                                                </t>
                                            </div>
                                            <div class="wpe-notif-card-type">
                                                <span class="badge bg-light text-dark">
                                                    <i t-attf-class="fa #{item['icon']} me-1"/>
                                                    <t t-esc="item.get('activity_type', 'Activity')"/>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="wpe-notif-card-hint">
                                            <span class="wpe-unread-dot"/>
                                            <i class="fa fa-angle-right text-muted"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="wpe-notif-empty text-center text-muted py-5">
                            <i class="fa fa-check-circle fa-3x mb-3 d-block" style="opacity: 0.3;"/>
                            <p class="mb-0">沒有通知</p>
                        </div>
                    </t>
                </div>

                <!-- Swipe hint -->
                <t t-if="notification_items">
                    <div class="wpe-swipe-hint text-center text-muted mt-2 mb-4"
                         id="wpe_swipe_hint">
                        <i class="fa fa-long-arrow-right me-1"/>
                        向右滑動可標記為已讀 / 已完成
                    </div>
                </t>

            </div>

            <!-- ============================================================ -->
            <!-- Detail Modal (hidden, populated by JS)                       -->
            <!-- ============================================================ -->
            <div class="wpe-notif-modal-overlay" id="wpe_notif_modal_overlay"
                 style="display: none;">
                <div class="wpe-notif-modal" id="wpe_notif_modal">
                    <div class="wpe-notif-modal-header">
                        <h5 class="wpe-notif-modal-title" id="wpe_modal_title"/>
                        <button type="button" class="btn-close"
                                id="wpe_modal_close"/>
                    </div>
                    <div class="wpe-notif-modal-body" id="wpe_modal_body">
                        <!-- Populated dynamically by JS -->
                    </div>
                    <div class="wpe-notif-modal-footer" id="wpe_modal_footer">
                        <a href="#" class="btn btn-sm btn-outline-primary me-2"
                           id="wpe_modal_doc_link" target="_blank"
                           style="display: none;">
                            <i class="fa fa-external-link me-1"/>查看文件
                        </a>
                        <button type="button"
                                class="btn btn-sm btn-primary"
                                id="wpe_modal_action_btn"
                                style="display: none;">
                            <i class="fa fa-check me-1"/>標記已讀
                        </button>
                    </div>
                </div>
            </div>

        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Portal user dropdown: add "Return to Backend" for admins     -->
    <!-- ============================================================ -->
    <template id="portal_user_dropdown_backend_link" name="Portal Return to Backend"
              inherit_id="portal.user_dropdown" priority="20">
        <xpath expr="//*[@id='o_logout_divider']" position="before">
            <a groups="base.group_user" href="/odoo" role="menuitem"
               class="dropdown-item ps-3" id="wpe_return_backend_link">
                <i class="fa fa-fw fa-exchange me-1 small text-primary text-primary-emphasis"/>
                返回後台
            </a>
        </xpath>
    </template>

</odoo>
