<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Replace "My account" header with greeting card               -->
    <!-- ============================================================ -->
    <template id="portal_greeting_card" name="Woow Portal Greeting Card"
              inherit_id="portal.portal_layout" priority="10">

        <!-- Replace "My account" h3 + avatar button wrapper with greeting card -->
        <xpath expr="//div[hasclass('wrapper')][.//h3[contains(text(),'My account')]]" position="replace">
            <div class="wpe-greeting-card" t-if="my_details">
                <img class="wpe-greeting-avatar"
                     t-att-src="image_data_uri(user_id.partner_id.avatar_1024)"
                     t-att-alt="user_id.partner_id.name"/>
                <div class="wpe-greeting-text">
                    <h4>
                        <t t-if="greeting" t-esc="greeting"/><t t-if="not greeting">Hello</t>,
                        <t t-esc="greeting_name or user_id.partner_id.name"/>
                    </h4>
                    <p t-if="today_date_line1" class="mb-0">
                        <i class="fa fa-calendar-o me-1"/>
                        <t t-esc="today_date_line1"/>
                    </p>
                    <p t-if="today_date_line2" class="mb-0 wpe-greeting-time">
                        <i class="fa fa-clock-o me-1"/>
                        <t t-esc="today_date_line2"/>
                    </p>
                </div>
            </div>
        </xpath>

    </template>

    <!-- ============================================================ -->
    <!-- Inherit portal.portal_my_home to prepend search bar,         -->
    <!-- notification preview, and admin banner.                      -->
    <!-- ============================================================ -->
    <template id="portal_my_home_enhanced" name="Woow Enhanced Portal Home"
              inherit_id="portal.portal_my_home" priority="10">

        <!-- Search bar + Notification preview — before the module grid -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">

            <!-- ① Search Bar -->
            <div class="wpe-search-bar mb-3">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fa fa-search text-muted"/>
                    </span>
                    <input type="text"
                           id="wpe_module_search"
                           class="form-control border-start-0"
                           placeholder="搜尋模組或通知..."/>
                </div>
            </div>

            <!-- ② Notification Preview Card — grouped by type -->
            <div class="wpe-notification-preview card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0 fw-bold">
                            近期通知
                            <t t-if="total_unread_count">
                                <span class="badge bg-danger ms-2"
                                      style="font-size: 0.7rem; vertical-align: middle;">
                                    <t t-esc="total_unread_count"/>
                                </span>
                            </t>
                        </h5>
                        <a href="/my/notifications" class="wpe-view-all-link">
                            查看全部 <i class="fa fa-angle-right ms-1"/>
                        </a>
                    </div>

                    <t t-set="has_any" t-value="message_previews or sys_notif_previews or activity_previews"/>
                    <t t-if="has_any">

                        <!-- 留言 (Messages) -->
                        <t t-if="unread_message_count or message_previews">
                            <div class="wpe-preview-group-header d-flex align-items-center mb-2 mt-1">
                                <i class="fa fa-comment text-muted me-2"/>
                                <span class="fw-semibold small">留言</span>
                                <t t-if="unread_message_count">
                                    <span class="badge bg-danger ms-2" style="font-size: 0.65rem;">
                                        <t t-esc="unread_message_count"/>
                                    </span>
                                </t>
                            </div>
                            <t t-foreach="message_previews" t-as="notif">
                                <a href="/my/notifications?tab=message"
                                   class="wpe-notification-item d-flex align-items-start text-decoration-none">
                                    <div class="wpe-notification-icon me-3">
                                        <img t-att-src="notif.get('icon_img', '/woow_portal_enhanced/static/src/img/mdi/bell-outline.svg')"
                                             width="22" height="22" alt=""/>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold text-dark wpe-preview-title">
                                            <t t-esc="notif['subject']"/>
                                        </div>
                                        <small class="text-muted">
                                            <t t-esc="notif['record_name']"/>
                                            <t t-if="notif.get('author_name')">
                                                <span class="ms-2">
                                                    <i class="fa fa-user-o me-1"/>
                                                    <t t-esc="notif['author_name']"/>
                                                </span>
                                            </t>
                                        </small>
                                    </div>
                                    <i class="fa fa-angle-right text-muted align-self-center"/>
                                </a>
                            </t>
                            <t t-if="not message_previews and unread_message_count">
                                <a href="/my/notifications?tab=message"
                                   class="wpe-notification-item d-flex align-items-center text-decoration-none">
                                    <small class="text-muted">
                                        <t t-esc="unread_message_count"/> 則未讀留言
                                    </small>
                                    <i class="fa fa-angle-right text-muted ms-auto"/>
                                </a>
                            </t>
                        </t>

                        <!-- 通知 (System Notifications) -->
                        <t t-if="unread_sys_notif_count or sys_notif_previews">
                            <div class="wpe-preview-group-header d-flex align-items-center mb-2 mt-3">
                                <i class="fa fa-bell text-muted me-2"/>
                                <span class="fw-semibold small">通知</span>
                                <t t-if="unread_sys_notif_count">
                                    <span class="badge bg-danger ms-2" style="font-size: 0.65rem;">
                                        <t t-esc="unread_sys_notif_count"/>
                                    </span>
                                </t>
                            </div>
                            <t t-foreach="sys_notif_previews" t-as="notif">
                                <a href="/my/notifications?tab=notification"
                                   class="wpe-notification-item d-flex align-items-start text-decoration-none">
                                    <div class="wpe-notification-icon me-3">
                                        <img t-att-src="notif.get('icon_img', '/woow_portal_enhanced/static/src/img/mdi/bell-outline.svg')"
                                             width="22" height="22" alt=""/>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold text-dark wpe-preview-title">
                                            <t t-esc="notif['subject']"/>
                                        </div>
                                        <small class="text-muted">
                                            <t t-esc="notif['record_name']"/>
                                        </small>
                                    </div>
                                    <i class="fa fa-angle-right text-muted align-self-center"/>
                                </a>
                            </t>
                            <t t-if="not sys_notif_previews and unread_sys_notif_count">
                                <a href="/my/notifications?tab=notification"
                                   class="wpe-notification-item d-flex align-items-center text-decoration-none">
                                    <small class="text-muted">
                                        <t t-esc="unread_sys_notif_count"/> 則未讀通知
                                    </small>
                                    <i class="fa fa-angle-right text-muted ms-auto"/>
                                </a>
                            </t>
                        </t>

                        <!-- 待辦 (Activities) — internal users only -->
                        <t t-if="is_internal_user and (activity_count or activity_previews)">
                            <div class="wpe-preview-group-header d-flex align-items-center mb-2 mt-3">
                                <i class="fa fa-clock-o text-muted me-2"/>
                                <span class="fw-semibold small">待辦</span>
                                <t t-if="activity_count">
                                    <span class="badge bg-danger ms-2" style="font-size: 0.65rem;">
                                        <t t-esc="activity_count"/>
                                    </span>
                                </t>
                            </div>
                            <t t-foreach="activity_previews" t-as="act">
                                <a href="/my/notifications?tab=activity"
                                   class="wpe-notification-item d-flex align-items-start text-decoration-none">
                                    <div class="wpe-notification-icon me-3">
                                        <img t-att-src="act.get('icon_img', '/woow_portal_enhanced/static/src/img/mdi/bell-outline.svg')"
                                             width="22" height="22" alt=""/>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold text-dark wpe-preview-title">
                                            <t t-esc="act['summary']"/>
                                        </div>
                                        <small class="text-muted">
                                            <t t-esc="act['res_name']"/>
                                            <t t-if="act.get('date_deadline')">
                                                <span class="ms-2">
                                                    <i class="fa fa-calendar-o me-1"/>
                                                    <t t-esc="act['date_deadline']"/>
                                                </span>
                                            </t>
                                        </small>
                                    </div>
                                    <i class="fa fa-angle-right text-muted align-self-center"/>
                                </a>
                            </t>
                            <t t-if="not activity_previews and activity_count">
                                <a href="/my/notifications?tab=activity"
                                   class="wpe-notification-item d-flex align-items-center text-decoration-none">
                                    <small class="text-muted">
                                        <t t-esc="activity_count"/> 個待辦事項
                                    </small>
                                    <i class="fa fa-angle-right text-muted ms-auto"/>
                                </a>
                            </t>
                        </t>

                    </t>
                    <t t-else="">
                        <div class="text-center text-muted py-3">
                            <i class="fa fa-check-circle fa-2x mb-2 d-block"/>
                            沒有新的通知
                        </div>
                    </t>
                </div>
            </div>

            <!-- ③ Loyalty / eWallet Cards — exact copy of sidebar cards, 2-col grid -->
            <t t-if="cards_per_programs">
                <div class="o_loyalty_container row g-2 mb-4">
                    <t t-foreach="cards_per_programs" t-as="program">
                        <div class="portal-loyalty-buttons cursor-pointer col-6"
                             t-foreach="cards_per_programs[program]"
                             t-as="card">
                            <div class="o_loyalty_card d-flex h-100"
                                 t-att-data-card_id="card.id">
                                <span class="o_notification_bar rounded-start"
                                      style="width: 0.5rem; background-color: var(--cyan)"/>
                                <div class="w-100 py-3 ps-3 pe-5 border border-start-0 rounded-end d-flex flex-row gap-3">
                                    <img class="img-fluid"
                                         t-attf-src="/loyalty/static/src/img/{{ program.program_type }}.svg"
                                         width="40"/>
                                    <div class="d-flex flex-column gap-1">
                                        <div>
                                            <strong t-out="program.display_name"/>
                                        </div>
                                        <p id="card_points" class="m-0 text-600">
                                            <t t-out="card.points_display"/>
                                        </p>
                                        <t t-if="program.program_type == 'loyalty' and any(reward.required_points &lt;= card.points for reward in program.reward_ids)">
                                            <p class="m-0 text-info">A reward is waiting for you</p>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </t>

        </xpath>

        <!-- Wrap the module grid in our container for search filtering -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="attributes">
            <attribute name="id">wpe_module_grid</attribute>
        </xpath>

    </template>

    <!-- ============================================================ -->
    <!-- Notification List Page — /my/notifications                   -->
    <!-- 3 tabs: Mail Message / Mail Notification / Mail Activity     -->
    <!-- Portal users: Message + Notification only                    -->
    <!-- Backend users: all 3 tabs                                    -->
    <!-- ============================================================ -->
    <template id="portal_notifications_page" name="Portal Notifications Page">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <div class="container py-3">

                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <a href="/my/home" class="btn btn-sm btn-outline-secondary wpe-breadcrumb-back-btn">
                        <i class="fa fa-arrow-left me-1"/>返回
                    </a>
                    <h4 class="mb-0 fw-bold flex-grow-1 text-center">通知中心</h4>
                    <button type="button"
                            class="navbar-toggler border-0 p-1"
                            id="wpe_notif_searchbar_toggle"
                            aria-label="搜尋篩選">
                        <span class="fa fa-fw fa-bars"/>
                    </button>
                </div>

                <!-- Search / Filter / Sort / Group panel (hidden by default) -->
                <div class="wpe-notif-searchbar d-none mb-3" id="wpe_notif_searchbar">
                    <div class="bg-light border rounded p-3">

                        <!-- Sort By -->
                        <div class="mb-2">
                            <label class="form-label fw-semibold small mb-1">Sort By:</label>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-sort-btn active"
                                        data-sort="newest">Newest</button>
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-sort-btn"
                                        data-sort="oldest">Oldest</button>
                            </div>
                        </div>

                        <!-- Filter By -->
                        <div class="mb-2">
                            <label class="form-label fw-semibold small mb-1">Filter By:</label>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-filter-btn active"
                                        data-filter="all">All</button>
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-filter-btn"
                                        data-filter="unread">Unread</button>
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-filter-btn"
                                        data-filter="read">Read</button>
                            </div>
                        </div>

                        <!-- Group By -->
                        <div class="mb-2">
                            <label class="form-label fw-semibold small mb-1">Group By:</label>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-group-btn active"
                                        data-group="none">None</button>
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-group-btn"
                                        data-group="type">Type</button>
                                <button class="btn btn-sm btn-outline-secondary wpe-notif-group-btn"
                                        data-group="source">Source</button>
                            </div>
                        </div>

                        <!-- Search -->
                        <div class="mb-0">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white"><i class="fa fa-search text-muted"/></span>
                                <input type="text" class="form-control" id="wpe_notif_search_input"
                                       placeholder="Search"/>
                                <button class="btn btn-outline-secondary" type="button" id="wpe_notif_search_btn">
                                    <i class="fa fa-search"/>
                                </button>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Tabs (badges = unread count only, hidden when 0) -->
                <div class="wpe-notif-tabs mb-3">
                    <a t-attf-href="/my/notifications?tab=all"
                       t-attf-class="wpe-notif-tab #{'active' if current_tab == 'all' else ''}">
                        全部
                        <t t-if="unread_all_count">
                            <span class="badge bg-danger ms-1" data-unread-badge="all">
                                <t t-esc="unread_all_count"/>
                            </span>
                        </t>
                    </a>
                    <a t-attf-href="/my/notifications?tab=message"
                       t-attf-class="wpe-notif-tab #{'active' if current_tab == 'message' else ''}">
                        留言
                        <t t-if="unread_message_count">
                            <span class="badge bg-danger ms-1" data-unread-badge="message">
                                <t t-esc="unread_message_count"/>
                            </span>
                        </t>
                    </a>
                    <a t-attf-href="/my/notifications?tab=notification"
                       t-attf-class="wpe-notif-tab #{'active' if current_tab == 'notification' else ''}">
                        通知
                        <t t-if="unread_sys_notif_count">
                            <span class="badge bg-danger ms-1" data-unread-badge="notification">
                                <t t-esc="unread_sys_notif_count"/>
                            </span>
                        </t>
                    </a>
                    <!-- Activity tab: internal users only -->
                    <t t-if="is_internal_user">
                        <a t-attf-href="/my/notifications?tab=activity"
                           t-attf-class="wpe-notif-tab #{'active' if current_tab == 'activity' else ''}">
                            待辦
                            <t t-if="activity_count">
                                <span class="badge bg-danger ms-1">
                                    <t t-esc="activity_count"/>
                                </span>
                            </t>
                        </a>
                    </t>
                </div>

                <!-- Notification List -->
                <div class="wpe-notif-list" id="wpe_notif_list">
                    <t t-if="notification_items">
                        <t t-foreach="notification_items" t-as="item">
                            <!-- Notification-type item (mail.notification) -->
                            <t t-if="item.get('notif_id')">
                                <div t-attf-class="wpe-notif-card-wrapper #{'wpe-notif-read' if item['is_read'] else 'wpe-notif-unread'}"
                                     t-att-data-notif-id="item['notif_id']"
                                     data-item-type="notification">
                                    <div class="wpe-notif-swipe-bg">
                                        <i class="fa fa-check"/>
                                        <span>已讀</span>
                                    </div>
                                    <div class="wpe-notif-card" data-action="show-detail">
                                        <div class="wpe-notif-card-icon">
                                            <img t-att-src="item.get('icon_img', '/woow_portal_enhanced/static/src/img/mdi/bell-outline.svg')"
                                                 width="22" height="22" alt=""/>
                                        </div>
                                        <div class="wpe-notif-card-body">
                                            <div class="wpe-notif-card-title">
                                                <t t-esc="item['subject']"/>
                                            </div>
                                            <div class="wpe-notif-card-meta">
                                                <span class="wpe-notif-card-source">
                                                    <t t-esc="item['record_name']"/>
                                                </span>
                                                <span class="wpe-notif-card-date">
                                                    <t t-esc="item['time_ago']"/>
                                                </span>
                                            </div>
                                            <t t-if="item.get('tracking_summary')">
                                                <div class="wpe-notif-card-tracking">
                                                    <small class="text-muted">
                                                        <i class="fa fa-exchange me-1"/>
                                                        <t t-esc="item['tracking_summary']"/>
                                                    </small>
                                                </div>
                                            </t>
                                            <t t-if="item.get('body_preview') and not item.get('tracking_summary')">
                                                <div class="wpe-notif-card-preview">
                                                    <small class="text-muted">
                                                        <t t-esc="item['body_preview']"/>
                                                    </small>
                                                </div>
                                            </t>
                                        </div>
                                        <div class="wpe-notif-card-hint">
                                            <span t-attf-class="wpe-unread-dot #{'d-none' if item['is_read'] else ''}"
                                                  t-att-data-notif-id="item['notif_id']"/>
                                            <i class="fa fa-angle-right text-muted"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                            <!-- Activity-type item (mail.activity) -->
                            <t t-if="item.get('activity_id')">
                                <div class="wpe-notif-card-wrapper wpe-notif-unread"
                                     t-att-data-activity-id="item['activity_id']"
                                     data-item-type="activity">
                                    <div class="wpe-notif-swipe-bg">
                                        <i class="fa fa-check"/>
                                        <span>已完成</span>
                                    </div>
                                    <div class="wpe-notif-card" data-action="show-detail">
                                        <div class="wpe-notif-card-icon">
                                            <img t-att-src="item.get('icon_img', '/woow_portal_enhanced/static/src/img/mdi/bell-outline.svg')"
                                                 width="22" height="22" alt=""/>
                                        </div>
                                        <div class="wpe-notif-card-body">
                                            <div class="wpe-notif-card-title">
                                                <t t-esc="item['summary']"/>
                                            </div>
                                            <div class="wpe-notif-card-meta">
                                                <span class="wpe-notif-card-source">
                                                    <t t-esc="item['res_name']"/>
                                                </span>
                                                <t t-if="item.get('date_deadline')">
                                                    <span class="wpe-notif-card-date">
                                                        <i class="fa fa-calendar-o me-1"/>
                                                        <t t-esc="item['date_deadline']"/>
                                                    </span>
                                                </t>
                                            </div>
                                            <div class="wpe-notif-card-type">
                                                <span class="badge bg-light text-dark">
                                                    <t t-esc="item.get('activity_type', 'Activity')"/>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="wpe-notif-card-hint">
                                            <span class="wpe-unread-dot"/>
                                            <i class="fa fa-angle-right text-muted"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="wpe-notif-empty text-center text-muted py-5">
                            <i class="fa fa-check-circle fa-3x mb-3 d-block" style="opacity: 0.3;"/>
                            <p class="mb-0">沒有通知</p>
                        </div>
                    </t>
                </div>

                <!-- Swipe hint -->
                <t t-if="notification_items">
                    <div class="wpe-swipe-hint text-center text-muted mt-2 mb-4"
                         id="wpe_swipe_hint">
                        <i class="fa fa-long-arrow-right me-1"/>
                        向右滑動可標記為已讀 / 已完成
                    </div>
                </t>

            </div>

            <!-- ============================================================ -->
            <!-- Detail Modal (hidden, populated by JS)                       -->
            <!-- ============================================================ -->
            <div class="wpe-notif-modal-overlay" id="wpe_notif_modal_overlay"
                 style="display: none;">
                <div class="wpe-notif-modal" id="wpe_notif_modal">
                    <div class="wpe-notif-modal-header">
                        <h5 class="wpe-notif-modal-title" id="wpe_modal_title"/>
                        <button type="button" class="btn-close"
                                id="wpe_modal_close"/>
                    </div>
                    <div class="wpe-notif-modal-body" id="wpe_modal_body">
                        <!-- Populated dynamically by JS -->
                    </div>
                    <div class="wpe-notif-modal-footer" id="wpe_modal_footer">
                        <a href="#" class="btn btn-sm btn-outline-primary me-2"
                           id="wpe_modal_doc_link" target="_blank"
                           style="display: none;">
                            <i class="fa fa-external-link me-1"/>查看文件
                        </a>
                        <button type="button"
                                class="btn btn-sm btn-primary"
                                id="wpe_modal_action_btn"
                                style="display: none;">
                            <i class="fa fa-check me-1"/>標記已讀
                        </button>
                    </div>
                </div>
            </div>

        </t>
    </template>

    <!-- Footer: controlled by website module settings (removed override) -->

    <!-- Add wpe-mdi-icon class to all portal icons for transparent background -->
    <template id="portal_icon_transparent" name="MDI Icon: Transparent Background"
              inherit_id="portal.portal_docs_entry" priority="50">
        <xpath expr="//div[hasclass('o_portal_icon')]" position="attributes">
            <attribute name="class" add="wpe-mdi-icon" separator=" "/>
        </xpath>
    </template>

    <!-- Portal: Connection & Security — shield-lock-outline -->
    <template id="portal_icon_security" name="MDI Icon: Connection"
              inherit_id="portal.portal_my_home" priority="50">
        <xpath expr="//div[@id='portal_common_category']//t[@t-set='icon']" position="attributes">
            <attribute name="t-value">'/woow_portal_enhanced/static/src/img/mdi/shield-lock-outline.svg'</attribute>
        </xpath>
    </template>

    <!-- Hide sidebar loyalty cards (we show them in center instead) -->
    <template id="portal_hide_sidebar_loyalty" name="Hide Sidebar Loyalty Cards"
              inherit_id="loyalty.loyalty_buttons" priority="50">
        <xpath expr="//div[hasclass('o_loyalty_container')]" position="replace">
            <div class="o_loyalty_container d-none"/>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Task 5: Add back button before navbar-toggler in searchbar   -->
    <!-- ============================================================ -->
    <template id="portal_breadcrumb_back_btn" name="Breadcrumb Back Button"
              inherit_id="portal.portal_searchbar" priority="50">
        <xpath expr="//button[hasclass('navbar-toggler')]" position="before">
            <a href="#" class="btn btn-sm btn-outline-secondary wpe-breadcrumb-back-btn"
               onclick="event.preventDefault(); if (window.history.length > 1) { window.history.back(); } else { window.location.href='/my/home'; }">
                <i class="fa fa-arrow-left me-1"/>返回
            </a>
        </xpath>
    </template>

